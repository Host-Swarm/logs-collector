APP_NAME="Host Swarm Agent"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Authentication
# Shared secret used to authenticate GET /api/stacks and GET /api/stacks/{stack}.
SERVER_SECRET=change-me-to-a-long-random-secret

# Parent app (server-manager) Passport token validation
# Used to validate one-time tokens for /containers/{id}/logs and /containers/{id}/exec.
PARENT_APP_URL=http://server-manager
PARENT_APP_TOKEN_VERIFY_PATH=/api/token/verify
PARENT_APP_TIMEOUT=5

# Docker socket
DOCKER_SOCKET_PATH=/var/run/docker.sock
DOCKER_TIMEOUT=10
DOCKER_CONNECT_TIMEOUT=5
DOCKER_STREAM_TIMEOUT=0

# Swarm
LOG_COLLECTOR_SWARM_KEY=main-swarm
